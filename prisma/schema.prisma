// This is your Prisma schema file for Printsy.io
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// MODELOS DE USUÁRIO E AUTENTICAÇÃO
// =============================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  role      UserRole @default(USER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  createdQuotes Quote[] @relation("CreatedBy")
  createdOrders Order[] @relation("CreatedBy")
  createdInvoices Invoice[] @relation("CreatedBy")
  
  @@map("users")
}

// =============================================================================
// MODELOS DE CRM E CLIENTES
// =============================================================================

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String?  @unique
  phone       String?
  document    String?  // CPF/CNPJ
  type        CustomerType @default(INDIVIDUAL) // Pessoa física ou jurídica
  address     String?
  city        String?
  state       String?
  zipCode     String?
  notes       String?
  tags        String[] // Tags para categorização
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  quotes Quote[]
  orders Order[]
  invoices Invoice[]
  accountsReceivable AccountReceivable[]
  interactions CustomerInteraction[]
  
  @@map("customers")
}

model CustomerInteraction {
  id          String           @id @default(cuid())
  customerId  String
  type        InteractionType
  description String
  notes       String?
  date        DateTime         @default(now())
  
  // Relacionamentos
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@map("customer_interactions")
}

// =============================================================================
// MODELOS DE PRODUTOS E ESTOQUE
// =============================================================================

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  category    String
  unit        String      // unidade (un, kg, m², etc)
  price       Float       // preço base
  cost        Float?      // custo do produto
  stock       Int         @default(0)
  minStock    Int         @default(0)
  maxStock    Int?        // estoque máximo
  barcode     String?     // código de barras
  sku         String?     // SKU único
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relacionamentos
  quoteItems  QuoteItem[]
  orderItems  OrderItem[]
  invoiceItems InvoiceItem[]
  stockMovements StockMovement[]
  
  @@map("products")
}

model StockMovement {
  id          String        @id @default(cuid())
  productId   String
  type        MovementType
  quantity    Float
  unitPrice   Float?
  total       Float?
  reason      String        // motivo da movimentação
  reference   String?       // referência (número do pedido, nota fiscal, etc)
  createdAt   DateTime      @default(now())

  // Relacionamentos
  product Product @relation(fields: [productId], references: [id])
  
  @@map("stock_movements")
}

// =============================================================================
// MODELOS DE ORÇAMENTOS
// =============================================================================

model Quote {
  id          String      @id @default(cuid())
  number      String      @unique
  customerId  String
  userId      String
  title       String?     // título do orçamento
  description String?
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime
  discount    Float       @default(0)
  discountType DiscountType @default(PERCENTAGE)
  subtotal    Float       @default(0)
  total       Float       @default(0)
  notes       String?
  terms       String?     // termos e condições
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relacionamentos
  customer    Customer    @relation(fields: [customerId], references: [id])
  createdBy   User        @relation("CreatedBy", fields: [userId], references: [id])
  items       QuoteItem[]
  order       Order?      // um orçamento pode virar um pedido
  
  @@map("quotes")
}

model QuoteItem {
  id        String @id @default(cuid())
  quoteId   String
  productId String
  quantity  Float
  unitPrice Float
  discount  Float  @default(0)
  total     Float
  notes     String?

  // Relacionamentos
  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  
  @@map("quote_items")
}

// =============================================================================
// MODELOS DE PEDIDOS
// =============================================================================

model Order {
  id          String      @id @default(cuid())
  number      String      @unique
  customerId  String
  userId      String
  quoteId     String?     // opcional, pode ser criado direto sem orçamento
  title       String?
  description String?
  status      OrderStatus @default(PENDING)
  priority    Priority    @default(NORMAL)
  deadline    DateTime?
  startDate   DateTime?   // data de início da produção
  discount    Float       @default(0)
  discountType DiscountType @default(PERCENTAGE)
  subtotal    Float       @default(0)
  total       Float       @default(0)
  notes       String?
  production_notes String? // observações de produção
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relacionamentos
  customer    Customer    @relation(fields: [customerId], references: [id])
  createdBy   User        @relation("CreatedBy", fields: [userId], references: [id])
  quote       Quote?      @relation(fields: [quoteId], references: [id])
  items       OrderItem[]
  invoice     Invoice?    // um pedido pode gerar uma fatura
  
  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Float
  unitPrice Float
  discount  Float  @default(0)
  total     Float
  notes     String?

  // Relacionamentos
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  
  @@map("order_items")
}

// =============================================================================
// MODELOS FINANCEIROS E FATURAMENTO
// =============================================================================

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  customerId  String
  userId      String
  orderId     String?       // opcional
  type        InvoiceType   @default(SALE)
  status      InvoiceStatus @default(PENDING)
  issueDate   DateTime      @default(now())
  dueDate     DateTime
  paidDate    DateTime?
  subtotal    Float         @default(0)
  discount    Float         @default(0)
  tax         Float         @default(0)
  total       Float         @default(0)
  notes       String?
  
  // Relacionamentos
  customer Customer @relation(fields: [customerId], references: [id])
  createdBy User @relation("CreatedBy", fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])
  items InvoiceItem[]
  
  @@map("invoices")
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String
  productId String
  quantity  Float
  unitPrice Float
  discount  Float  @default(0)
  total     Float
  notes     String?

  // Relacionamentos
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  
  @@map("invoice_items")
}

model AccountReceivable {
  id          String        @id @default(cuid())
  customerId  String?
  invoiceId   String?       // opcional, pode ser uma receita avulsa
  description String
  amount      Float
  dueDate     DateTime
  paidDate    DateTime?
  status      PaymentStatus @default(PENDING)
  paymentMethod String?     // método de pagamento
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relacionamentos
  customer Customer? @relation(fields: [customerId], references: [id])
  
  @@map("accounts_receivable")
}

model AccountPayable {
  id          String        @id @default(cuid())
  description String
  amount      Float
  dueDate     DateTime
  paidDate    DateTime?
  status      PaymentStatus @default(PENDING)
  category    String
  supplier    String?
  paymentMethod String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@map("accounts_payable")
}

// =============================================================================
// MODELOS DE CONFIGURAÇÃO E SISTEMA
// =============================================================================

model CompanySettings {
  id        String   @id @default(cuid())
  name      String
  document  String   // CNPJ
  email     String
  phone     String
  address   String
  city      String
  state     String
  zipCode   String
  logo      String?  // caminho para o logo
  website   String?
  theme     String   @default("light")
  language  String   @default("pt-BR")
  timezone  String   @default("America/Sao_Paulo")
  currency  String   @default("BRL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("company_settings")
}

model SystemNotification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean  @default(false)
  userId    String?  // se null, é para todos os usuários
  createdAt DateTime @default(now())
  
  @@map("system_notifications")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum CustomerType {
  INDIVIDUAL  // Pessoa física
  COMPANY     // Pessoa jurídica
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  QUOTE_SENT
  ORDER_CREATED
  PAYMENT_RECEIVED
  OTHER
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  DELIVERED
  CANCELLED
}

enum InvoiceType {
  SALE
  SERVICE
  ADVANCE
  REFUND
}

enum InvoiceStatus {
  PENDING
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}